<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f7f7f5;
      --card: #ffffff;
      --text: #1c1c1e;
      --muted: #6b6b70;
      --border: #e5e5e2;
      --accent: #b5502f;      /* warm terracotta */
      --badge-bg: #ecebff;
      --badge-text: #4a3fbd;
      --link: #1e5aa8;
      --chip-bg: #ffffff;
      --chip-active-bg: #b5502f;
      --chip-active-text: #ffffff;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #16161a;
        --card: #1f1f24;
        --text: #ececed;
        --muted: #9a9aa2;
        --border: #2c2c32;
        --accent: #e08a63;
        --badge-bg: #2a2850;
        --badge-text: #b9b4ff;
        --link: #7fb0ea;
        --chip-bg: #1f1f24;
        --chip-active-bg: #e08a63;
        --chip-active-text: #16161a;
      }
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font: 16px/1.6 "Lora", Georgia, "Times New Roman", serif;
    }
    .wrap { max-width: 780px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }
    header { border-bottom: 2px solid var(--accent); padding-bottom: 1rem; margin-bottom: 1.5rem; }
    h1 { font-size: 2rem; font-weight: 700; margin: 0 0 .25rem; letter-spacing: -0.01em; }
    .meta { color: var(--muted); font-size: .9rem; font-style: italic; }

    /* Filter chips */
    .filters { display: flex; flex-wrap: wrap; gap: .45rem; margin-bottom: 2rem; }
    .chip {
      font: 500 .82rem/1 "Lora", Georgia, serif;
      background: var(--chip-bg); color: var(--text);
      border: 1px solid var(--border); border-radius: 999px;
      padding: .42rem .8rem; cursor: pointer; transition: all .12s ease;
    }
    .chip:hover { border-color: var(--accent); }
    .chip.active {
      background: var(--chip-active-bg); color: var(--chip-active-text);
      border-color: var(--chip-active-bg);
    }

    h2 {
      font-size: .82rem; text-transform: uppercase; letter-spacing: .09em;
      color: var(--accent); margin: 2.25rem 0 .75rem; font-weight: 700;
    }
    ul { list-style: none; margin: 0; padding: 0; }
    li {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: .9rem 1.1rem; margin-bottom: .6rem;
    }
    .headline { font-weight: 600; font-size: 1.06rem; margin: 0 0 .25rem; }
    .headline a { color: var(--text); text-decoration: none; }
    .headline a:hover { color: var(--link); text-decoration: underline; }
    .summary { margin: .2rem 0 .45rem; }
    .source { color: var(--muted); font-size: .82rem; font-style: italic; }
    .badge {
      display: inline-block; font: 700 .66rem/1 "Lora", serif;
      text-transform: uppercase; letter-spacing: .05em; font-style: normal;
      background: var(--badge-bg); color: var(--badge-text);
      padding: .16rem .4rem; border-radius: 5px; margin-left: .4rem; vertical-align: middle;
    }
    footer { margin-top: 3rem; color: var(--muted); font-size: .82rem; font-style: italic;
             border-top: 1px solid var(--border); padding-top: 1rem; }
    .empty { color: var(--muted); font-style: italic; }
    a { color: var(--link); }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <h1>{{ title }}</h1>
      <div class="meta">
        {{ generated_at }} &middot; {{ total }} stor{{ 'y' if total == 1 else 'ies' }}
        {%- if ai_count %} &middot; {{ ai_count }} AI-related{% endif %}
      </div>
    </header>

    {% if groups %}
    <nav class="filters" aria-label="Filter by section">
      <button class="chip active" data-filter="all">All</button>
      {% for category, slug, items in groups %}
        <button class="chip" data-filter="{{ slug }}">{{ category }}</button>
      {% endfor %}
    </nav>
    {% endif %}

    {% if total == 0 %}
      <p class="empty">No stories matched today. Try widening the recency window in
      sources.yaml, or check your feeds with <code>--check-sources</code>.</p>
    {% endif %}

    {% for category, slug, items in groups %}
      <section class="digest-section" data-category="{{ slug }}">
        <h2 id="{{ slug }}">{{ category }}</h2>
        <ul>
          {% for a in items %}
            <li>
              <p class="headline">
                <a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.title }}</a>
                {%- if a.ai_related %}<span class="badge">AI</span>{% endif %}
              </p>
              {% if a.one_liner %}<p class="summary">{{ a.one_liner }}</p>{% endif %}
              <p class="source">{{ a.source }}</p>
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endfor %}

    <footer>
      Generated by <strong>Career Headlines</strong> — a personal daily digest.
      Summaries by the Claude API.
    </footer>
  </div>

  <script>
    // Filter chips: clicking one shows only that section; "All" shows everything.
    // Pure vanilla JS, no dependencies. With JavaScript off, every section is
    // simply visible — the page degrades gracefully.
    (function () {
      const chips = document.querySelectorAll(".chip");
      const sections = document.querySelectorAll(".digest-section");
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const filter = chip.dataset.filter;
          chips.forEach((c) => c.classList.toggle("active", c === chip));
          sections.forEach((s) => {
            s.style.display =
              filter === "all" || s.dataset.category === filter ? "" : "none";
          });
        });
      });
    })();
  </script>
</body>
</html>

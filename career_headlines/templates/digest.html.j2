<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    :root {
      --bg: #f7f7f5;
      --card: #ffffff;
      --text: #1c1c1e;
      --muted: #6b6b70;
      --border: #e5e5e2;
      --accent: #b5502f;      /* warm terracotta */
      --badge-bg: #ecebff;
      --badge-text: #4a3fbd;
      --link: #1e5aa8;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #16161a;
        --card: #1f1f24;
        --text: #ececed;
        --muted: #9a9aa2;
        --border: #2c2c32;
        --accent: #e08a63;
        --badge-bg: #2a2850;
        --badge-text: #b9b4ff;
        --link: #7fb0ea;
      }
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font: 16px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
            Helvetica, Arial, sans-serif;
    }
    .wrap { max-width: 760px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }
    header { border-bottom: 2px solid var(--accent); padding-bottom: 1rem; margin-bottom: 2rem; }
    h1 { font-size: 1.9rem; margin: 0 0 .25rem; letter-spacing: -0.01em; }
    .meta { color: var(--muted); font-size: .9rem; }
    h2 {
      font-size: .8rem; text-transform: uppercase; letter-spacing: .08em;
      color: var(--accent); margin: 2.5rem 0 .75rem; font-weight: 700;
    }
    ul { list-style: none; margin: 0; padding: 0; }
    li {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: .9rem 1.1rem; margin-bottom: .6rem;
    }
    .headline { font-weight: 600; margin: 0 0 .2rem; }
    .headline a { color: var(--text); text-decoration: none; }
    .headline a:hover { color: var(--link); text-decoration: underline; }
    .summary { color: var(--text); margin: .15rem 0 .4rem; }
    .source { color: var(--muted); font-size: .82rem; }
    .badge {
      display: inline-block; font-size: .68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .04em;
      background: var(--badge-bg); color: var(--badge-text);
      padding: .1rem .4rem; border-radius: 5px; margin-left: .4rem; vertical-align: middle;
    }
    footer { margin-top: 3rem; color: var(--muted); font-size: .82rem;
             border-top: 1px solid var(--border); padding-top: 1rem; }
    .empty { color: var(--muted); font-style: italic; }
    a { color: var(--link); }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <h1>{{ title }}</h1>
      <div class="meta">
        {{ generated_at }} &middot; {{ total }} stor{{ 'y' if total == 1 else 'ies' }}
        {%- if ai_count %} &middot; {{ ai_count }} AI-related{% endif %}
      </div>
    </header>

    {% if total == 0 %}
      <p class="empty">No stories matched today. Try widening the recency window or
      checking your feeds with <code>--check-sources</code>.</p>
    {% endif %}

    {% for category, items in groups %}
      <h2>{{ category }}</h2>
      <ul>
        {% for a in items %}
          <li>
            <p class="headline">
              <a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.title }}</a>
              {%- if a.ai_related %}<span class="badge">AI</span>{% endif %}
            </p>
            {% if a.one_liner %}<p class="summary">{{ a.one_liner }}</p>{% endif %}
            <p class="source">{{ a.source }}</p>
          </li>
        {% endfor %}
      </ul>
    {% endfor %}

    <footer>
      Generated by <strong>Career Headlines</strong> — a personal daily digest.
      Summaries by the Claude API.
    </footer>
  </div>
</body>
</html>
